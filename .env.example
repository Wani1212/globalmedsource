# Gmail SMTP credentials
#
# IMPORTANT — You must use a Gmail App Password, NOT your regular Gmail password.
# Regular passwords will be rejected by Gmail's SMTP server.
#
# How to generate a Gmail App Password:
#   1. Go to myaccount.google.com → Security
#   2. Enable "2-Step Verification" if you haven't already
#   3. Return to Security → scroll down to "2-Step Verification" → click it
#   4. Scroll to the bottom and click "App passwords"
#   5. Select app: "Mail", select device: "Other (custom name)", type "GlobalMedSource"
#   6. Click "Generate" — copy the 16-character password shown (no spaces)
#   7. Paste it as EMAIL_PASS below
#
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=xxxx_xxxx_xxxx_xxxx
EMAIL_TO=aryanwani2@gmail.com
PORT=3000
